<Window x:Class="DoAn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DoAn"
        mc:Ignorable="d"
        Title="Quản lý Nhân Viên" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6" FontFamily="Segoe UI">
    <Border CornerRadius="20" Background="White" >
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="20,0,0,20">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#2193b0" Offset="0"/>
                        <GradientStop Color="#6dd5ed" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="HR TECH" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Quản lý nhân sự hiện đại" Foreground="White" FontSize="14" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="50,0">
                <TextBlock Text="Chào mừng trở lại!" FontSize="28" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                <TextBlock Text="Vui lòng đăng nhập để tiếp tục" Foreground="Gray" Margin="0,0,0,30"/>

                <TextBlock Text="Tên đăng nhập" Margin="0,10,0,5" FontWeight="Medium"/>
                <TextBox x:Name="txtUser" Height="40" VerticalContentAlignment="Center" Padding="10,0" 
                         BorderBrush="#DDD" BorderThickness="0,0,0,2"/>

                <TextBlock Text="Mật khẩu" Margin="0,20,0,5" FontWeight="Medium"/>
                <PasswordBox x:Name="txtPass" Height="40" VerticalContentAlignment="Center" Padding="10,0" 
                             BorderBrush="#DDD" BorderThickness="0,0,0,2"/>

                <Button Content="ĐĂNG NHẬP" Click="BtnLogin_Click" Margin="0,40,0,0" Height="45" Cursor="Hand"
                        Background="#2193b0" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Text="Quên mật khẩu?" Foreground="#2193b0" Margin="0,15,0,0" 
                     HorizontalAlignment="Center" Cursor="Hand"
                     MouseLeftButtonDown="TextBlock_ForgotPass_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

