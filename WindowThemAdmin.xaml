<Window x:Class="DoAn.WindowThemAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm tài khoản Admin" Height="300" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Tên Tài Khoản:" FontWeight="Bold"/>
            <TextBox x:Name="txtUser" Height="30"/>

            <TextBlock Text="Mật Khẩu:" FontWeight="Bold"/>
            <TextBox x:Name="txtPass" Height="30"/>

            <TextBlock Text="Chọn Nhân Viên Sở Hữu:" FontWeight="Bold"/>
            <ComboBox x:Name="cboNhanVien" Height="30"
                      DisplayMemberPath="HoVaTen" SelectedValuePath="MaNhanVien" SelectionChanged="cboNhanVien_SelectionChanged"/>

            <Button Content="Tạo Tài Khoản" Click="BtnTao_Click" Height="35" Background="#10B981" Foreground="White"/>
            <Button Content="Hủy" Click="BtnHuy_Click" Height="35" Background="#EF4444" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
