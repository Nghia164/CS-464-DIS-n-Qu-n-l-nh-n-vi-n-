<Window x:Class="DoAn.NhanVienWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DoAn"
        mc:Ignorable="d"
        Title="Quản Lý Nhân Viên" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen" 
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Margin="10">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2B3649"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827">
            <StackPanel>
                <TextBlock Text="Quản Lý Nhân Viên" Foreground="White" FontSize="20" FontWeight="Bold" 
                           Margin="35,40,0,40" />

                <Button x:Name="btnTongQuan" Click="btnTongQuan_Click"  Content="📊  Tổng Quan" Style="{StaticResource MenuButtonStyle}" />
                <Button x:Name="btnNhanVien" Click="btnNhanVien_Click" Content="👥  Nhân Viên" Style="{StaticResource MenuButtonStyle}" Background="#1F2937" Foreground="White"/>
                <Button x:Name="btnTuyenDung" Click="btnTuyenDung_Click" Content="📅  Tuyển Dụng" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="btnHieuSuat" Click="btnHieuSuat_Click" Content="📈  Hiệu Suất" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="btnLuongThuong" Click="btnLuongThuong_Click" Content="💰  Lương Thưởng" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="btnCaiDat" Click="btnCaiDat_Click" Content="⚙️  Cài Đặt" Style="{StaticResource MenuButtonStyle}" />
                <Button x:Name="btnThoat" Click="btnThoat_Click" Content="❌  Thoát" Style="{StaticResource MenuButtonStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20" LastChildFill="False">
                <TextBlock Text="Hồ Sơ Nhân Viên" FontSize="22" FontWeight="Bold" 
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>

                <Button x:Name="btnAdmin" Click="btnAdmin_Click" Content="+ Thêm Admin" 
                        DockPanel.Dock="Right" Background="#10B981" Foreground="White" 
                        Padding="15,8" BorderThickness="0" Width="130" Margin="5,0,0,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnXoa" Click="btnXoa_Click" Content="Xóa" 
                        DockPanel.Dock="Right" Background="#EF4444" Foreground="White" 
                        Padding="15,8" BorderThickness="0" Width="100" Margin="5,0,0,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnSua" Click="btnSua_Click" Content="Sửa" 
                        DockPanel.Dock="Right" Background="#F59E0B" Foreground="White" 
                        Padding="15,8" BorderThickness="0" Width="100" Margin="5,0,0,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnThem" Click="btnThem_Click" Content="+ Thêm Mới" 
                        DockPanel.Dock="Right" Background="#2563EB" Foreground="White" 
                        Padding="15,8" BorderThickness="0" Width="130" Margin="5,0,0,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </DockPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <DataGrid x:Name="dgNhanVien" AutoGenerateColumns="False" CanUserAddRows="False" 
                          BorderThickness="0" Background="White" RowHeight="50" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã NV" Binding="{Binding MaNhanVien}" Width="70"/>
                        <DataGridTextColumn Header="Họ Tên" Binding="{Binding HoVaTen}" Width="160"/>
                        <DataGridTextColumn Header="Phòng Ban" Binding="{Binding TenPhongBan}" Width="140"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="170"/>
                        <DataGridTextColumn Header="SĐT" Binding="{Binding SoDienThoai}" Width="110"/>
                        <DataGridTextColumn Header="Ngày Vào Làm" Binding="{Binding NgayVaoLam, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>

                        <DataGridTemplateColumn Header="Trạng Thái" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#DCFCE7" CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,4">
                                        <TextBlock Text="{Binding TrangThaiLamViec}" Foreground="#16A34A" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>