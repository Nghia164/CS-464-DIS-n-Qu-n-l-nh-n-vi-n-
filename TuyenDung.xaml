<Window x:Class="DoAn.TuyenDung"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DoAn"
        mc:Ignorable="d"
        Title="Quản Lý Tuyển Dụng" Height="720" Width="1200" 
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Margin="10">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2B3649"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827">
            <StackPanel>
                <TextBlock Text="Quản Lý Nhân Viên" Foreground="White" FontSize="20" FontWeight="Bold" Margin="35,40,0,40" />

                <Button x:Name="btnTongQuan" Click="btnTongQuan_Click" Content="📊  Tổng Quan" Style="{StaticResource MenuButtonStyle}" />
                <Button x:Name="btnNhanVien" Click="btnNhanVien_Click" Content="👥  Nhân Viên" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="btnTuyenDung" Click="btnTuyenDung_Click" Content="📅  Tuyển Dụng" Style="{StaticResource MenuButtonStyle}" Background="#1F2937" Foreground="White"/>
                <Button x:Name="btnHieuSuat" Click="btnHieuSuat_Click" Content="📈  Hiệu Suất" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="btnLuongThuong" Click="btnLuongThuong_Click" Content="💰  Lương Thưởng" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="btnCaiDat" Click="btnCaiDat_Click" Content="⚙️  Cài Đặt" Style="{StaticResource MenuButtonStyle}" />
                <Button x:Name="btnThoat" Click="btnThoat_Click" Content="❌  Thoát" Style="{StaticResource MenuButtonStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20" LastChildFill="False">
                <TextBlock Text="Vị Trí Đang Tuyển" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button x:Name="btnTaoTinTuyenDung" Content="+ Tạo Tin Tuyển Dụng" Click="btnTaoTinTuyenDung_Click" DockPanel.Dock="Right" Background="#2563EB" Foreground="White" Padding="20,8" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" BorderThickness="0">
                <ItemsControl x:Name="icTuyenDung">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="400" Height="180" Background="White" CornerRadius="12" Margin="0,0,20,20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#E0E0E0" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                                </Border.Effect>
                                <Grid Margin="20">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ViTri}" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SoLuong, StringFormat='Số lượng: \{0\}'}" Foreground="Gray" Margin="0,5"/>
                                        <TextBlock Text="{Binding PhongBan}" Foreground="{Binding MauPhongBan}" FontWeight="SemiBold"/>

                                        <ProgressBar Value="{Binding PhanTram}" Height="8" Margin="0,20,0,5" Foreground="{Binding MauPhongBan}" BorderThickness="0" Background="#E5E7EB"/>

                                        <DockPanel>
                                            <TextBlock Text="{Binding DaNhan, StringFormat='Đã nhận \{0\} hồ sơ'}" FontSize="11" Foreground="#6B7280" DockPanel.Dock="Right"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>