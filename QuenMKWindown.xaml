<Window x:Class="DoAn.QuenMKWindown"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DoAn"
        mc:Ignorable="d"
        Title="Lấy lại mật khẩu" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        ResizeMode="NoResize" Background="Transparent" AllowsTransparency="True">

    <Border CornerRadius="20" Background="White" BorderBrush="#2193b0" BorderThickness="1">
        <Grid Margin="20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="ĐẶT LẠI MẬT KHẨU" FontSize="24" FontWeight="Bold" 
                           Foreground="#2193b0" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Tên đăng nhập:" Margin="0,10,0,5"/>
                <TextBox x:Name="txtUser" Height="35" Padding="5"/>

                <TextBlock Text=" Mã nhân viên:" Margin="0,10,0,5"/>
                <TextBox x:Name="txtM" Height="35" Padding="5"/>

                <TextBlock Text="Mật khẩu mới:" Margin="0,10,0,5"/>
                <PasswordBox x:Name="txtNewPass" Height="35" Padding="5"/>

                <Button Content="XÁC NHẬN ĐỔI MK" Height="40" Margin="0,30,0,0"
                        Background="#2193b0" Foreground="White" FontWeight="Bold"
                        Click="BtnConfirm_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Hủy bỏ" Height="35" Margin="0,10,0,0"
                        Background="Transparent" Foreground="Gray" BorderThickness="0"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
