<Window x:Class="DoAn.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DoAn"
        mc:Ignorable="d"
        Title="Quản lý Hiệu Suất" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Margin="10,2">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2B3649"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827">
            <StackPanel>
                <TextBlock Text="Quản Lý" Foreground="White" FontSize="20" FontWeight="Bold" Margin="35,40,0,40" />

                <Button x:Name="btnTongQuan" Content="📊  Tổng Quan" Style="{StaticResource MenuButtonStyle}" Click="btnTongQuan_Click"/>
                <Button x:Name="btnNhanVien" Content="👥  Nhân Viên" Style="{StaticResource MenuButtonStyle}" Click="btnNhanVien_Click"/>
                <Button x:Name="btnTuyenDung" Content="📅  Tuyển Dụng" Style="{StaticResource MenuButtonStyle}" Click="btnTuyenDung_Click"/>
                <Button x:Name="btnHieuSuat" Content="📈  Hiệu Suất" Style="{StaticResource MenuButtonStyle}" Background="#1F2937" Foreground="White" Click="btnHieuSuat_Click"/>
                <Button x:Name="btnLuongThuong" Content="💰  Lương Thưởng" Style="{StaticResource MenuButtonStyle}" Click="btnLuongThuong_Click"/>
                <Button x:Name="btnCaiDat" Content="⚙️  Cài Đặt" Style="{StaticResource MenuButtonStyle}" Click="btnCaiDat_Click" />
                <Button x:Name="btnThoat" Content="❌  Thoát" Style="{StaticResource MenuButtonStyle}" Click="btnThoat_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,30" LastChildFill="False">
                <StackPanel>
                    <TextBlock Text="Hiệu Suất &amp; Đánh Giá" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Cập nhật lần cuối: Hôm nay" FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
                </StackPanel>

                <Border DockPanel.Dock="Right" Background="White" CornerRadius="8" Padding="5" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#E0E0E0" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                    </Border.Effect>
                    <ComboBox SelectedIndex="0" BorderThickness="0" Background="Transparent" Padding="10,5" FontWeight="SemiBold" Width="120" Cursor="Hand">
                        <ComboBoxItem Content="Tháng này"/>
                        <ComboBoxItem Content="Quý này"/>
                        <ComboBoxItem Content="Năm nay"/>
                    </ComboBox>
                </Border>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <Grid Margin="20">
                        <StackPanel>
                            <TextBlock Text="Điểm Đánh Giá TB" Foreground="Gray" FontSize="13"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock x:Name="txtDiemTB" Text="4.8" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                                <TextBlock Text="/ 5.0" FontSize="16" Foreground="Gray" VerticalAlignment="Bottom" Margin="5,0,0,6"/>
                            </StackPanel>
                            <TextBlock Text="▲ 12% so với tháng trước" FontSize="12" Foreground="#16A34A" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Border Width="40" Height="40" Background="#FFF7ED" CornerRadius="20" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBlock Text="⭐" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#F59E0B" FontSize="18"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <Grid Margin="20">
                        <StackPanel>
                            <TextBlock Text="Dự Án Hoàn Thành" Foreground="Gray" FontSize="13"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock x:Name="txtDuAn" Text="92" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                                <TextBlock Text="%" FontSize="20" Foreground="#111827" VerticalAlignment="Bottom" Margin="2,0,0,6"/>
                            </StackPanel>
                            <ProgressBar x:Name="pbDuAn" Value="92" Height="6" Background="#F1F5F9" Foreground="#3B82F6" BorderThickness="0" Margin="0,10,0,0"/>
                        </StackPanel>
                        <Border Width="40" Height="40" Background="#EFF6FF" CornerRadius="20" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBlock Text="🚀" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#3B82F6" FontSize="18"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                    <Grid Margin="20">
                        <StackPanel>
                            <TextBlock Text="Giờ Làm Hiệu Quả" Foreground="Gray" FontSize="13"/>
                            <TextBlock x:Name="txtGioLam" Text="1,240h" FontSize="36" FontWeight="Bold" Foreground="#111827" Margin="0,10,0,0"/>
                            <TextBlock Text="▼ 2% giờ OT (Tốt)" FontSize="12" Foreground="#16A34A" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Border Width="40" Height="40" Background="#F0FDF4" CornerRadius="20" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBlock Text="⏱️" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#16A34A" FontSize="18"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,20,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#E0E0E0" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid Margin="25">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Xu Hướng Hiệu Suất (6 tháng)" FontSize="16" FontWeight="Bold" Foreground="#111827"/>

                        <Viewbox Grid.Row="1" Margin="10,20,10,10" Stretch="Fill">
                            <Canvas Width="600" Height="200">
                                <Line X1="0" Y1="50" X2="600" Y2="50" Stroke="#F1F5F9" StrokeThickness="1"/>
                                <Line X1="0" Y1="100" X2="600" Y2="100" Stroke="#F1F5F9" StrokeThickness="1"/>
                                <Line X1="0" Y1="150" X2="600" Y2="150" Stroke="#F1F5F9" StrokeThickness="1"/>

                                <Polyline Points="0,150 100,120 200,60 300,90 400,40 500,20 600,30" 
                                          Stroke="#3B82F6" StrokeThickness="3">
                                    <Polyline.Effect>
                                        <DropShadowEffect Color="#3B82F6" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                                    </Polyline.Effect>
                                </Polyline>

                                <TextBlock Text="T7" Canvas.Top="170" Canvas.Left="0" Foreground="Gray"/>
                                <TextBlock Text="T8" Canvas.Top="170" Canvas.Left="100" Foreground="Gray"/>
                                <TextBlock Text="T9" Canvas.Top="170" Canvas.Left="200" Foreground="Gray"/>
                                <TextBlock Text="T10" Canvas.Top="170" Canvas.Left="300" Foreground="Gray"/>
                                <TextBlock Text="T11" Canvas.Top="170" Canvas.Left="400" Foreground="Gray"/>
                                <TextBlock Text="T12" Canvas.Top="170" Canvas.Left="500" Foreground="#3B82F6" FontWeight="Bold"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#E0E0E0" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Top Nhân Viên" FontSize="16" FontWeight="Bold" Foreground="#111827"/>

                        <DataGrid x:Name="dgTopNhanVien" Grid.Row="1" Margin="0,15,0,0" 
                                  AutoGenerateColumns="False" CanUserAddRows="False" BorderThickness="0" 
                                  Background="White" RowHeight="60" IsReadOnly="True" HeadersVisibility="None" 
                                  GridLinesVisibility="None">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="40" Height="40" Background="{Binding RankColor, FallbackValue='#FFD700'}" CornerRadius="20">
                                                <TextBlock Text="{Binding RankIcon, FallbackValue='🥇'}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="5,0">
                                                <TextBlock Text="{Binding HoVaTen}" FontWeight="SemiBold" FontSize="14" Foreground="#111827"/>
                                                <TextBlock Text="{Binding TenPhongBan}" FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Binding="{Binding DiemKPI, StringFormat={}{0:N1}}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#16A34A"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>