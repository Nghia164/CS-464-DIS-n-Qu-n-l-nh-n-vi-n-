<Window x:Class="DoAn.Window5"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DoAn"
        mc:Ignorable="d"
        Title="Bảng Lương &amp; Thâm Niên" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen" 
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Margin="10">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2B3649"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827">
            <StackPanel>
                <TextBlock Text="Quản Lý Nhân Viên" Foreground="White" FontSize="20" FontWeight="Bold" Margin="35,40,0,40" />

                <Button x:Name="btnTongQuan" Click="btnTongQuan_Click"  Content="📊  Tổng Quan" Style="{StaticResource MenuButtonStyle}" />
                <Button x:Name="btnNhanVien" Click="btnNhanVien_Click" Content="👥  Nhân Viên" Style="{StaticResource MenuButtonStyle}" />
                <Button x:Name="btnTuyenDung" Click="btnTuyenDung_Click" Content="📅  Tuyển Dụng" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="btnHieuSuat" Click="btnHieuSuat_Click" Content="📈  Hiệu Suất" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="btnLuongThuong" Click="btnLuongThuong_Click" Content="💰  Lương Thưởng" Style="{StaticResource MenuButtonStyle}" Background="#1F2937" Foreground="White"/>
                <Button x:Name="btnCaiDat" Click="btnCaiDat_Click" Content="⚙️  Cài Đặt" Style="{StaticResource MenuButtonStyle}" />
                <Button x:Name="btnThoat" Click="btnThoat_Click" Content="❌  Thoát" Style="{StaticResource MenuButtonStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20" LastChildFill="False">
                <TextBlock Text="Bảng Lương" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" DockPanel.Dock="Left"/>

                <Button x:Name="btnXuatExcel" Click="btnXuatExcel_Click" Content="Xuất Excel" DockPanel.Dock="Right" Background="#10B981" Foreground="White" Padding="15,8" BorderThickness="0" Width="110" Margin="5,0,0,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnCapNhat" Click="btnCapNhat_Click" Content="Cập Nhật" DockPanel.Dock="Right" Background="#F59E0B" Foreground="White" Padding="15,8" BorderThickness="0" Width="100" Margin="5,0,0,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnTinhLuong" Click="btnTinhLuong_Click" Content="Tính Lương" DockPanel.Dock="Right" Background="#2563EB" Foreground="White" Padding="15,8" BorderThickness="0" Width="110" Margin="5,0,0,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </DockPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <DataGrid x:Name="dgDanhSachLuong" AutoGenerateColumns="False" CanUserAddRows="False" BorderThickness="0" Background="White" RowHeight="50" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" Margin="8,0,-2,0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã NV" Binding="{Binding MaNhanVien}" Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Họ Tên" Binding="{Binding HoVaTen}" Width="150"/>

                        <DataGridTextColumn Header="Phòng Ban" Binding="{Binding TenPhongBan}" Width="120"/>

                        <DataGridTextColumn Header="Kỳ Lương" Binding="{Binding KyLuong}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Ngày Công" Binding="{Binding SoNgayCong}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Phụ Cấp" Binding="{Binding PhuCap, StringFormat=\{0:N0\}}" Width="100"/>

                        <DataGridTextColumn Header="Thưởng" Binding="{Binding Thuong, StringFormat=\{0:N0\}}" Width="100"/>

                        <DataGridTextColumn Header="Thực Lĩnh (VNĐ)" Binding="{Binding ThucLinh, StringFormat=\{0:N0\}}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#2563EB"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Trạng Thái" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#DCFCE7" CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,4">
                                        <TextBlock Text="{Binding TrangThaiThanhToan}" Foreground="#16A34A" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>